{
    "name": "kode/process",
    "description": "高性能 PHP 进程与线程管理器，支持 Master-Worker 模型、进程池、IPC 通信、信号处理、队列消费，兼容 PHP 8.1-8.5+",
    "type": "library",
    "keywords": ["php", "process", "thread", "worker", "ipc", "signal", "pool", "fiber", "coroutine", "multiprocessing", "queue"],
    "license": "Apache-2.0",
    "version": "2.3.1",
    "authors": [
        {
            "name": "KodePHP Team",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "ext-sockets": "*",
        "kode/context": "^2.0",
        "kode/fibers": "^2.9",
        "kode/queue": "^1.0",
        "psr/log": "^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "swoole/ide-helper": "^5.0"
    },
    "suggest": {
        "ext-sysvmsg": "用于 System V 消息队列 IPC",
        "ext-sysvshm": "用于共享内存 IPC",
        "ext-sysvsem": "用于信号量同步",
        "ext-pthreads": "用于多线程支持",
        "ext-swoole": "用于 Swoole 协程进程管理",
        "kode/runtime": "用于运行时环境适配（Swoole/Swow/Fiber/Process/Thread）"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Process\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Process\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "2.3-dev"
        }
    }
}
